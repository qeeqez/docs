{
  "name": "rixl-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "bun lint && vite build && bun run build:md && bun run build:og",
    "build:md": "bun ./scripts/generate-md.ts",
    "build:og": "bun ./scripts/generate-og.ts",
    "dev": "vite dev",
    "start": "vite preview",
    "serve": "bunx serve@latest dist/client -l 4173",
    "serve:spa": "bunx serve@latest -s dist/client -l 4173",
    "lint": "oxlint --max-warnings=0 && fumadocs-mdx",
    "lint:links": "bun ./scripts/lint.ts",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-presence": "^1.1.5",
    "@rixl/videosdk-react": "^0.26.1",
    "@scalar/api-reference-react": "^0.8.24",
    "@takumi-rs/image-response": "^0.70.1",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-start": "^1.166.1",
    "@tanstack/start-static-server-functions": "^1.166.1",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "^10.3.14",
    "fumadocs-ui": "16.6.8",
    "lucide-react": "^0.576.0",
    "lucide-static": "^0.576.0",
    "nitro": "^2.2.28",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.5.2",
    "@types/bun": "^1.3.6",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "next-validate-link": "^1.6.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.59.2"
  },
  "packageManager": "bun@1.3.6"
}
