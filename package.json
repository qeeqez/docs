{
  "name": "rixl-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "bun run clean && bun lint && vite build",
    "clean": "rm -rf dist",
    "dev": "vite dev",
    "start": "vite preview",
    "serve": "bunx serve@latest --no-port-switching dist/client -l tcp://127.0.0.1:4173",
    "serve:spa": "bunx serve@latest --no-port-switching -s dist/client -l tcp://127.0.0.1:4173",
    "lint": "oxlint --max-warnings=0 && fumadocs-mdx",
    "lint:links": "bun ./scripts/lint.ts",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-presence": "^1.1.5",
    "@rixl/videosdk-react": "^0.27.0",
    "@takumi-rs/image-response": "^0.73.1",
    "@tanstack/react-router": "^1.168.1",
    "@tanstack/react-router-devtools": "^1.166.10",
    "@tanstack/react-start": "^1.167.2",
    "@tanstack/start-static-server-functions": "^1.166.17",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.7.3",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-openapi": "^10.4.1",
    "fumadocs-ui": "^16.7.3",
    "lucide-react": "^0.577.0",
    "lucide-static": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/bun": "^1.3.11",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "next-validate-link": "^1.6.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  },
  "packageManager": "bun@1.3.10"
}
